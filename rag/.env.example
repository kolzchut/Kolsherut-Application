# Server
RAG_SERVER_HOST=0.0.0.0
RAG_SERVER_PORT=8200

# Elasticsearch
ELASTIC_URL=https://srm-staging-elasticsearch.whiletrue.industries
ELASTIC_USERNAME=elastic
ELASTIC_PASS=

# Indexes
CARDS_INDEX_NAME=srm__cards
CARD_ID_FIELD_NAME=card_id
RAG_EMBEDDINGS_INDEX_NAME=srm__cards_rag_embeddings

# Logging (ask logs roll into a weekly index: {RAG_LOGS_INDEX_NAME}_{week}_{year})
RAG_LOGS_INDEX_NAME=srm__rag_ask_logs
RAG_LOG_LEVEL=INFO

# Embedding
EMBEDDING_MODEL_PATH=artifacts/retrieval-model
# E5-style text prefixes - set both to empty for models that do not use them
EMBEDDING_PASSAGE_PREFIX="passage: "
EMBEDDING_QUERY_PREFIX="query: "
# Card text structure (macros + templates) lives in app/strings.py, not here.
# Nested-item sub-fields read off situations/responses/URL objects.
CARD_NESTED_ITEM_NAME_FIELD=name
CARD_NESTED_ITEM_SYNONYMS_FIELD=synonyms
CARD_NESTED_ITEM_TITLE_FIELD=title
CARD_NESTED_ITEM_HREF_FIELD=href
# Reindex scan/embed batching.
CARD_SCAN_BATCH_SIZE=500
CARD_SCAN_SCROLL_KEEP_ALIVE=30m
CARD_EMBED_BATCH_SIZE=64

# Retrieval
RETRIEVAL_TOP_K=5
KNN_NUM_CANDIDATES=100
# Per-retriever candidate depth (kNN + BM25) feeding the reciprocal rank fusion.
CANDIDATE_POOL_SIZE=50
# Rank constant in the reciprocal rank fusion score 1 / (rank_constant + rank).
RRF_RANK_CONSTANT=60

# LLM (OpenAI-format key, OpenAI-compatible endpoint serving the Gemini model)
OPENAI_API_KEY=
LLM_MODEL_NAME=gemini-3.1-flash-lite
LLM_BASE_URL=
LLM_MAX_TOKENS=1024

# Reranker (cross-encoder that rescores the fused candidate pool)
RERANKER_MODEL_PATH=artifacts/reranker-model
# Top fused docs the cross-encoder rescores (latency knob: ~1.4s at 10, ~2.4s at 20 on CPU).
RERANK_POOL_SIZE=20
# Max token length per (query, document) pair fed to the cross-encoder.
# bge-reranker-v2-m3 full context, so pairs are never truncated.
RERANKER_MAX_LENGTH=8192
