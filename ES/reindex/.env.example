# Copy this file to `.env` (same folder) and fill in the real values.
# `.env` is git-ignored so credentials never get committed.
#
# Before running setup-database.ps1, start a port-forward to the remote ES, e.g.:
#   kubectl port-forward svc/<elasticsearch-service> 9201:9200
# so the remote cluster is reachable on http://127.0.0.1:9201.
#
# NOTE: use 127.0.0.1, NOT localhost. On Windows with WSL/Docker Desktop,
# "localhost" can resolve to IPv6 (::1) where a WSL relay squats the port and
# does not forward to the container, causing connection timeouts. 127.0.0.1
# forces IPv4, which Docker's port proxy actually serves.

# ---- Source (remote, port-forwarded) Elasticsearch: what we copy FROM ----
SOURCE_ES_URL=http://127.0.0.1:9201
SOURCE_ES_USERNAME=elastic
SOURCE_ES_PASSWORD=CHANGE_ME

# ---- Target (local) Elasticsearch: what we copy INTO (started by this script) ----
LOCAL_ES_URL=http://127.0.0.1:9200

# ---- Which indices to replicate (comma-separated patterns). ----
# These are the only two index families the BE reads (see be/src/vars.ts).
INDEX_PATTERNS=srm__cards_*,srm__autocomplete_*

# ---- Copy tuning ----
SCROLL_BATCH_SIZE=1000
SCROLL_TIMEOUT=2m
