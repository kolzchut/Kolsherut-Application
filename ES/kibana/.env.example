# Copy this file to `.env` (same folder) and point Kibana at the Elasticsearch you want.
# `.env` is git-ignored so credentials never get committed.
#
# NOTE: use 127.0.0.1 / host.docker.internal, NOT localhost. On Windows with WSL/Docker
# Desktop, "localhost" can resolve to IPv6 (::1) where a WSL relay squats the port and does
# not forward to the container. Docker's port proxy serves IPv4, so host.docker.internal
# (which maps to the host's IPv4) always works from inside the Kibana container.

# ---- Which Elasticsearch Kibana connects to ----
# Pick ONE and put it here (uncomment the one you want):
#
#   Local replica started by ES/reindex (security disabled, no auth):
ELASTICSEARCH_HOSTS=http://host.docker.internal:9200
#
#   A port-forwarded remote cluster, e.g. kubectl port-forward svc/<es> 9201:9200:
# ELASTICSEARCH_HOSTS=http://host.docker.internal:9201
#
#   A reachable remote cluster directly:
# ELASTICSEARCH_HOSTS=https://srm-staging-elasticsearch.whiletrue.industries

# ---- Auth ----
# Leave BOTH blank for a security-disabled cluster (the ES/reindex local replica).
# Fill them in for a secured cluster.
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ---- TLS ----
# "none" skips certificate verification (fine for dev / self-signed https clusters).
# Set to "full" to verify certificates.
ELASTICSEARCH_SSL_VERIFICATIONMODE=none
