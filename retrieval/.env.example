# Server
RETRIEVAL_SERVER_HOST=0.0.0.0
RETRIEVAL_SERVER_PORT=8200

# Elasticsearch
ELASTIC_URL=https://srm-staging-elasticsearch.whiletrue.industries
ELASTIC_USERNAME=elastic
ELASTIC_PASS=

# Indexes
SERVICES_INDEX_NAME=srm_services
SERVICE_ID_FIELD_NAME=id
RETRIEVAL_EMBEDDINGS_INDEX_NAME=srm__services_retrieval_embeddings

# Logging (retrieval logs roll into a weekly index: {RETRIEVAL_LOGS_INDEX_NAME}_{week}_{year})
RETRIEVAL_LOGS_INDEX_NAME=srm__retrieval_logs
RETRIEVAL_LOG_LEVEL=INFO

# Embedding
EMBEDDING_MODEL_PATH=artifacts/retrieval-model
# E5-style text prefixes - set both to empty for models that do not use them
EMBEDDING_PASSAGE_PREFIX="passage: "
EMBEDDING_QUERY_PREFIX="query: "
# Service embedding text structure (field map + templates) lives in app/strings.py, not here.
# Reindex scan/embed batching.
SERVICE_SCAN_BATCH_SIZE=500
SERVICE_SCAN_SCROLL_KEEP_ALIVE=30m
SERVICE_EMBED_BATCH_SIZE=64

# Retrieval
KNN_NUM_CANDIDATES=100
# Per-retriever candidate depth (kNN + BM25) feeding the reciprocal rank fusion.
CANDIDATE_POOL_SIZE=50
# Rank constant in the reciprocal rank fusion score 1 / (rank_constant + rank).
RRF_RANK_CONSTANT=60
# Minimum fused RRF score to return a service (rank-based ~0.01-0.03, tune empirically).
MIN_FUSED_SCORE=0.0
