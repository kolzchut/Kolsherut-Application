# The retrieval embedding model (stock intfloat/multilingual-e5-large) is shipped
# in-repo via Git LFS so CI can COPY it into the image. Large binaries only; the
# small JSON configs stay as plain text so they remain diffable.
retrieval/artifacts/retrieval-model/**/*.safetensors filter=lfs diff=lfs merge=lfs -text
retrieval/artifacts/retrieval-model/**/*.bin filter=lfs diff=lfs merge=lfs -text
retrieval/artifacts/retrieval-model/**/*.model filter=lfs diff=lfs merge=lfs -text
retrieval/artifacts/retrieval-model/**/tokenizer.json filter=lfs diff=lfs merge=lfs -text
